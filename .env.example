# ===========================================
# POWER BI CHAT INTEGRATION - Environment Variables
# Copie este arquivo para .env e preencha os valores
# ===========================================

# ── Azure AD ──────────────────────────────────────────────────
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# ── Power BI ───────────────────────────────────────────────────
POWERBI_WORKSPACE_ID=your-workspace-id
POWERBI_DATASET_ID=your-dataset-id
POWERBI_REPORT_ID=your-report-id

# ── Anthropic (Claude) ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── App ────────────────────────────────────────────────────────
DEBUG=false
ENVIRONMENT=development

# ── Reports (links públicos Power BI) ──────────────────────────
# Adicione quantos relatórios quiser no array JSON
POWERBI_REPORTS=[{"name":"Relatório de Vendas","url":"https://app.powerbi.com/view?r=..."},{"name":"Outro Relatório","url":"https://app.powerbi.com/view?r=..."}]
